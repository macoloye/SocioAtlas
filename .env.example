OPENAI_API_KEY=token...
PORT=3001
MODEL_NAME=GPT-4o
BASE_URL_NAME=None

SAMPLE_SIZE=15              # total agents per simulation (dashboard can override if you wire it)
AGENT_BATCH_LIMIT=10        # agents per LLM call batch
MAX_CONCURRENT_REQUEST=3    # max concurrent LLM batch calls

# Optional: override default path (defaults to socioatlas/persona.json)
# PERSONA_JSON_PATH=/absolute/path/to/persona.json